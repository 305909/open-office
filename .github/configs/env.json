{
  /*
   |--------------------------------------------------------------------------
   | Evaluation Weights
   |--------------------------------------------------------------------------
   | The "weights" section assigns importance to different document components.
   | These weights influence the scoring system in the evaluation process.
   |
   | The values are expressed as proportions (0 to 1) and should ideally sum up
   | to 1.0 (100%). However, minor deviations may be acceptable depending on
   | the evaluation logic.
   |
   | Attributes:
   | - paragraphs: Determines the significance of paragraph structure and coherence.
   | - images: Measures the contribution of image presence and alignment.
   | - tables: Evaluates the importance of structured tables and data clarity.
   | - margins: Assesses the adherence to required document margins and spacing.
   |--------------------------------------------------------------------------
   */
  "weights": {
    "paragraphs": 0.35,  // Weight assigned to paragraph formatting and quality.
    "images": 0.25,      // Weight for image placement, quality, and relevance.
    "tables": 0.15,      // Weight for table organization and structural accuracy.
    "margins": 0.25      // Weight for proper margins and page layout consistency.
  },

  /*
   |--------------------------------------------------------------------------
   | Evaluation Tolerances
   |--------------------------------------------------------------------------
   | The "tolerances" section defines the acceptable range of variations in
   | different document elements. These parameters establish thresholds for
   | compliance without being overly rigid, allowing for minor deviations
   | where necessary.
   |
   | Attributes:
   | - empty_lines: The maximum number of consecutive empty lines permitted.
   | - paragraph_similarity_threshold: The minimum similarity ratio (0-1) that
   |   paragraphs must meet to be considered structurally sound.
   | - paragraph_bonus: Additional scoring awarded for well-structured paragraphs.
   | - image_dimension_tolerance: The allowed deviation in image dimensions before
   |   penalties apply.
   | - table_rows_tolerance: The permissible row variance in tables.
   | - table_columns_tolerance: The permissible column variance in tables.
   | - margin_tolerance: The extent to which margin deviations are acceptable.
   |--------------------------------------------------------------------------
   */
  "tolerances": {
    "empty_lines": 1,                      // Maximum number of consecutive empty lines allowed.
    "paragraph_similarity_threshold": 0.85, // Minimum similarity threshold for paragraph analysis.
    "paragraph_bonus": 1,                   // Bonus points for well-structured paragraphs.
    "image_dimension_tolerance": 1,         // Tolerance level for image size variations.
    "table_rows_tolerance": 1,              // Permissible deviation in table row count.
    "table_columns_tolerance": 1,           // Permissible deviation in table column count.
    "margin_tolerance": 1                    // Acceptable margin variation threshold.
  },

  /*
   |--------------------------------------------------------------------------
   | Additional Notes
   |--------------------------------------------------------------------------
   | - Ensure that modifications to the weight distribution remain logical.
   |--------------------------------------------------------------------------
   */
}
